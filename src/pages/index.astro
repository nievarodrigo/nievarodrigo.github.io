---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
---

<Layout>
  <Header />
  <main id="main-content" class="app-layout">
    <section id="hero" class="py-16 border-b border-border">
      <div class="text-accent text-xs tracking-widest uppercase mb-4">> Backend Developer</div>
      <h1 class="text-5xl font-bold text-white mb-6">Rodrigo Nieva</h1>
      <h3 class="text-2xl font-bold text-white mb-6">PYTHON // JAVA //   SQL</h3>
      <p class="text-lg text-muted-foreground leading-relaxed max-w-2xl">
        Desarrollador Backend especializado en construir arquitecturas escalables y sistemas orientados a datos. 
        Diseño APIs desde cero y transformo flujos de datos complejos en productos funcionales que potencian la operatividad del negocio.
      </p>
      <div class="mt-8 flex gap-4">
        <a href="#projects" class="bg-accent text-black px-6 py-2 font-bold uppercase text-xs tracking-widest">Ver proyectos</a>
        <a href="#contact" class="border border-border px-6 py-2 text-xs uppercase tracking-widest text-muted hover:text-accent">Contacto</a>
      </div>
    </section>

    <section id="skills" class="py-16 border-b border-border">
      <h2 class="text-2xl font-bold text-white mb-8">// Tecnologías</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="p-6 bg-surface border border-border">
          <h3 class="text-accent text-sm font-bold mb-4">BACKEND</h3>
          <p class="text-xs text-muted leading-loose">Python, FastAPI, SQLAlchemy, Pydantic, Java, SpringBoot, JUnit</p>
        </div>
        <div class="p-6 bg-surface border border-border">
          <h3 class="text-accent text-sm font-bold mb-4">DATOS</h3>
          <p class="text-xs text-muted leading-loose">SQL, MySQL, SQL Server, PowerBI, ETL, Normalización</p>
        </div>
        <div class="p-6 bg-surface border border-border">
          <h3 class="text-accent text-sm font-bold mb-4">CLOUD & TOOLS</h3>
          <p class="text-xs text-muted leading-loose">Git, Google Cloud Platform, Scrum, Agile, Requisitos</p>
        </div>
      </div>
    </section>

    <section id="projects" class="py-16 border-b border-border">
      <h2 class="text-2xl font-bold text-white mb-8">// Soluciones con impacto real</h2>
      <ul class="grid md:grid-cols-2 gap-4">
        {featuredPosts.map(data => <Card variant="h3" {...data} />)}
      </ul>
    </section>

    <section id="experience" class="py-16 border-b border-border">
      <h2 class="text-2xl font-bold text-white mb-8">// Trayectoria profesional</h2>
      <div class="flex flex-col md:flex-row gap-8">
        <div class="text-xs text-muted uppercase tracking-widest min-w-[200px]">Sept. 2025 — Actualidad</div>
        <div>
          <h3 class="text-xl text-white font-bold">Backend & Data Developer</h3>
          <div class="text-accent text-xs font-bold mb-4 uppercase">Freelance · Autónomo</div>
          <p class="text-sm text-muted leading-relaxed">
            Desarrollo de soluciones de software a medida y arquitecturas de datos enfocadas en resolver ineficiencias operativas. APIs con FastAPI y pipelines ETL con Python.
          </p>
        </div>
      </div>
    </section>

    <section id="education" class="py-16 border-b border-border">
      <div class="text-accent text-[0.6rem] tracking-[0.4em] uppercase mb-4">// Educación & Cursos</div>
      <h2 class="text-3xl font-bold text-white mb-10">Formación</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-1 bg-border border border-border">
        
        <div class="p-8 bg-background">
          <div class="text-accent2 text-[0.6rem] uppercase tracking-widest mb-4">Grado universitario</div>
          <h3 class="text-xl text-white font-bold mb-2">Ingeniería en Informática</h3>
          <p class="text-sm text-muted mb-4">UADE — Universidad Argentina de la Empresa</p>
          <div class="text-[0.65rem] text-border uppercase tracking-wider">Ago. 2022 — Ago. 2027 (En curso)</div>
        </div>

        <div class="p-8 bg-background">
          <div class="text-accent2 text-[0.6rem] uppercase tracking-widest mb-4">Curso</div>
          <h3 class="text-xl text-white font-bold mb-2">Generative AI Zero to Hero Academy</h3>
          <p class="text-sm text-muted mb-4">Google</p>
          <div class="text-[0.65rem] text-border uppercase tracking-wider">2026</div>
        </div>

        <div class="p-8 bg-background">
          <div class="text-accent2 text-[0.6rem] uppercase tracking-widest mb-4">Curso</div>
          <h3 class="text-xl text-white font-bold mb-2">Google Cloud Computing Foundations</h3>
          <p class="text-sm text-muted mb-4">Google</p>
          <div class="text-[0.65rem] text-border uppercase tracking-wider">2026</div>
        </div>

      </div>
    </section>

    <section id="contact" class="py-16 text-center">
      <h2 class="text-3xl font-bold text-white mb-6">¿Trabajamos juntos?</h2>
      <p class="text-muted max-w-xl mx-auto mb-10 text-sm">
        Disponible para posiciones de Backend Developer. Si buscás a alguien que construya sistemas robustos y orientados a datos, hablemos.
      </p>
      <div class="flex justify-center gap-6">
        <Socials />
      </div>
    </section>
  </main>
  <Footer />
</Layout>